{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Molt",
  "scopeName": "source.molt",
  "patterns": [
    {
      "include": "#expression"
    }
  ],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#import-decl" },
        { "include": "#export-decl" },
        { "include": "#named-function-signature" },
        { "include": "#anonymous-function-signature" },
        { "include": "#function-alias" },
        { "include": "#record-literal" },
        { "include": "#quote-block" },
        { "include": "#mutation-block" },
        { "include": "#function-call" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#mutation-capture" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#wildcard" },
        { "include": "#identifiers" }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.molt",
          "match": "#.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.molt",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.molt" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.molt" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.molt",
              "match": "\\\\(?:[\\\\\"nrt0])"
            }
          ]
        }
      ]
    },

    "import-decl": {
      "patterns": [
        {
          "comment": "import \"path\" as alias",
          "name": "meta.import.module-alias.molt",
          "match": "\\b(import)\\s+(\"[^\"]*\")\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.module.molt" },
            "2": { "name": "string.quoted.double.molt" },
            "3": { "name": "keyword.control.module.molt" },
            "4": { "name": "entity.name.namespace.molt" }
          }
        },
        {
          "comment": "import \"path\"",
          "name": "meta.import.module.molt",
          "match": "\\b(import)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.module.molt" },
            "2": { "name": "string.quoted.double.molt" }
          }
        },
        {
          "comment": "import {a, b} from \"path\"",
          "name": "meta.import.named-list.molt",
          "begin": "\\b(import)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.module.molt" },
            "2": { "name": "punctuation.section.block.begin.molt" }
          },
          "end": "(\\})\\s*(from)\\b",
          "endCaptures": {
            "1": { "name": "punctuation.section.block.end.molt" },
            "2": { "name": "keyword.control.module.molt" }
          },
          "patterns": [
            {
              "name": "entity.name.namespace.molt",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.molt",
              "match": ","
            }
          ]
        },
        {
          "comment": "import name from \"path\"",
          "name": "meta.import.named.molt",
          "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(from)\\b",
          "captures": {
            "1": { "name": "keyword.control.module.molt" },
            "2": { "name": "entity.name.namespace.molt" },
            "3": { "name": "keyword.control.module.molt" }
          }
        }
      ]
    },

    "export-decl": {
      "patterns": [
        {
          "name": "meta.export.molt",
          "match": "\\b(export)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.module.molt" },
            "2": { "name": "entity.name.molt" }
          }
        }
      ]
    },

    "named-function-signature": {
      "patterns": [
        {
          "name": "meta.function.molt",
          "begin": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.molt" },
            "2": { "name": "entity.name.function.molt" },
            "3": { "name": "punctuation.section.parameters.begin.molt" }
          },
          "end": "(\\))(?=\\s*=)",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.molt" }
          },
          "patterns": [
            { "include": "#parameter-items" }
          ]
        }
      ]
    },

    "anonymous-function-signature": {
      "patterns": [
        {
          "name": "meta.function.anonymous.molt",
          "begin": "\\b(fn)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.molt" },
            "2": { "name": "punctuation.section.parameters.begin.molt" }
          },
          "end": "(\\))(?=\\s*=)",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.molt" }
          },
          "patterns": [
            { "include": "#parameter-items" }
          ]
        }
      ]
    },

    "function-alias": {
      "patterns": [
        {
          "name": "meta.function.alias.molt",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*=)",
          "captures": {
            "1": { "name": "storage.type.function.molt" },
            "2": { "name": "entity.name.function.molt" }
          }
        }
      ]
    },

    "parameter-items": {
      "patterns": [
        {
          "name": "variable.parameter.molt",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.parameter.molt",
          "match": ","
        }
      ]
    },

    "record-literal": {
      "patterns": [
        {
          "name": "meta.record.molt",
          "begin": "\\b(record)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.other.record.molt" },
            "2": { "name": "punctuation.section.block.begin.molt" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.block.end.molt" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#record-field" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "record-field": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "variable.other.property.molt" },
            "2": { "name": "punctuation.separator.colon.molt" }
          }
        }
      ]
    },

    "quote-block": {
      "patterns": [
        {
          "name": "meta.quote.block.molt",
          "begin": "@\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.quote.begin.molt" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.quote.end.molt" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#unquote-expr" },
            { "include": "#splice-expr" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "unquote-expr": {
      "patterns": [
        {
          "name": "meta.unquote.molt",
          "begin": "(~)(\\()",
          "beginCaptures": {
            "1": { "name": "keyword.operator.unquote.molt" },
            "2": { "name": "punctuation.section.group.begin.molt" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.section.group.end.molt" }
          },
          "patterns": [
            { "include": "#expression" }
          ]
        }
      ]
    },

    "splice-expr": {
      "patterns": [
        {
          "name": "meta.splice.molt",
          "begin": "(~)(\\[)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.splice.molt" },
            "2": { "name": "punctuation.section.list.begin.molt" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.list.end.molt" }
          },
          "patterns": [
            { "include": "#expression" }
          ]
        }
      ]
    },

    "mutation-block": {
      "patterns": [
        {
          "name": "meta.mutation.block.molt",
          "begin": "~\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.mutation.begin.molt" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.mutation.end.molt" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#mutation-capture" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "mutation-capture": {
      "patterns": [
        {
          "name": "variable.other.capture.rest.molt",
          "match": "\\.\\.\\.\\$[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other.capture.molt",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "name": "support.function.call.molt",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.module.molt",
          "match": "\\b(?:import|export|from|as)\\b"
        },
        {
          "name": "keyword.control.conditional.molt",
          "match": "\\b(?:if|else)\\b"
        },
        {
          "name": "keyword.control.match.molt",
          "match": "\\bmatch\\b"
        },
        {
          "name": "keyword.control.loop.molt",
          "match": "\\b(?:while|for|in|break|continue)\\b"
        },
        {
          "name": "keyword.control.exception.molt",
          "match": "\\b(?:try|catch)\\b"
        },
        {
          "name": "keyword.other.record.molt",
          "match": "\\brecord\\b"
        },
        {
          "name": "keyword.operator.logical.molt",
          "match": "\\b(?:and|or|not)\\b"
        },
        {
          "name": "storage.type.function.molt",
          "match": "\\bfn\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.molt",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.nil.molt",
          "match": "\\bnil\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.molt",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },

    "wildcard": {
      "patterns": [
        {
          "name": "variable.language.wildcard.molt",
          "match": "\\b_\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.molt",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.molt",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.molt",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.molt",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ellipsis.molt",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.mutation.molt",
          "match": "~"
        },
        {
          "name": "keyword.operator.quote.molt",
          "match": "@"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.molt",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.molt",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.molt",
          "match": "\\."
        },
        {
          "name": "punctuation.section.group.begin.molt",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.molt",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.list.begin.molt",
          "match": "\\["
        },
        {
          "name": "punctuation.section.list.end.molt",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.block.begin.molt",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.molt",
          "match": "\\}"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.molt",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
