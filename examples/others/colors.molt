import collections from "std:collections"
import io from "std:io"
import strings from "std:strings"

colors = record {
    reset: "\e[0m",
    red: "\e[31m",
    green: "\e[32m",
    yellow: "\e[33m",
    blue: "\e[34m",
    magenta: "\e[35m",
    cyan: "\e[36m"
}

fn pretty_print(text, color) = {
    if collections.contains(colors, color) ->
        io.print(strings.join([colors[color], text, colors.reset], ""))
    else ->
        io.print(text)
}

pretty_print("hi in red", "red")
pretty_print("hi in green", "green")
pretty_print("hi in yellow", "yellow")
pretty_print("hi in blue", "blue")
pretty_print("hi in magenta", "magenta")
pretty_print("hi in cyan", "cyan")
