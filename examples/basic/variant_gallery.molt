import collections from "std:collections"
import io from "std:io"
import meta from "std:meta"

fn run(code, mutation) = meta.eval(code ~ mutation)

xs = []
collections.push(xs, run(@{ 2 + 3 }, ~{ + -> * }))
collections.push(xs, run(@{ collections.len("molt") + 1 }, ~{ 1 -> 3 }))
collections.push(xs, meta.type(@{ 0 }))

io.print(xs)
